# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Android Google Maps API key, injected into the native build by app.config.js.
# Restrict it in Google Cloud Console to your Android package name
# (com.kodou.app) + signing certificate so it's safe even if it leaks.
GOOGLE_MAPS_ANDROID_API_KEY=YOUR_ANDROID_GOOGLE_MAPS_API_KEY
