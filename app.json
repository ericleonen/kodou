{
  "expo": {
    "name": "Kodou",
    "slug": "kodou",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F01030",
      "imageWidth": 578
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kodou.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.kodou.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F01030"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-audio",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationWhenInUsePermission": "Kodou uses your location to measure your pace and distance while you run.",
          "locationAlwaysAndWhenInUsePermission": "Kodou keeps tracking your run in the background so your stats and program keep working with the screen off."
        }
      ],
      [
        "react-native-maps",
        {}
      ],
      "expo-font",
      "expo-splash-screen"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "edbd5978-41a1-452e-8126-96fda52b660e"
      }
    },
    "owner": "ericleonen"
  }
}
